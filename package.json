			"dist/nodes/Feilian/Feilian.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/node": "^20.19.37",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"glob": "^10.4.5"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
